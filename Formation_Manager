    function Part2B_Algo() {
      const [startDate, setStartDate] = useState('2026-02-01');
      const [endDate, setEndDate] = useState('2026-02-28');
      const [vacation, setVacation] = useState(10);
      const [absenteeism, setAbsenteeism] = useState(0);
      const [category, setCategory] = useState('IC');
      const [wr, setWr] = useState(80);
      const [exp, setExp] = useState(100);
      const [gen, setGen] = useState(10);
      
      const [exCapaInput, setExCapaInput] = useState('');
      const [exStatus, setExStatus] = useState(null);

      const { content = {}, gainXp, completedTasks, isDevMode } = useContext(window.ContentContext) || {};

      useEffect(() => {
        if (completedTasks && completedTasks['ex_p2_algo']) {
          setExStatus('success');
          setExCapaInput('61');
        } else if (isDevMode) {
          setExCapaInput('61');
          setExStatus(null);
        } else {
          setExStatus(null);
          setExCapaInput('');
        }
      }, [completedTasks, isDevMode]);

      const calculateWeekdays = (startStr, endStr) => {
        const s = new Date(startStr);
        const e = new Date(endStr);
        if (isNaN(s) || isNaN(e) || s > e) return 0;
        let count = 0;
        let cur = new Date(s);
        while (cur <= e) {
          const day = cur.getDay();
          if (day !== 0 && day !== 6) count++;
          cur.setDate(cur.getDate() + 1);
        }
        return count;
      };

      const workingDays = calculateWeekdays(startDate, endDate);
      const catHours = category === 'IC' ? 42.5 : 37.5;
      const baseHPerDay = catHours / 5;
      const kr = baseHPerDay * (wr/100) * (exp/100) * (1 - gen/100);
      const kg = (1 - vacation/100) * (1 - absenteeism/100);
      const net = workingDays * kr * kg;

      const checkExercise = () => {
        const val = parseFloat(exCapaInput.replace(',', '.'));
        if (Math.round(val) === 61 || val === 61.2) {
           setExStatus('success');
           if(gainXp) gainXp('ex_p2_algo');
        } else {
           setExStatus('error');
        }
      }

      return (
        <div className="space-y-6 animate-fade-in">
        
          <div className="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">

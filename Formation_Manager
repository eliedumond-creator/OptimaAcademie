<!DOCTYPE html>
<html lang="fr">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Formation OPTIMA - Portail Manager S&OP</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    /* --- Styles from Style.html --- */
    @keyframes fadeIn { 
      from { opacity: 0; transform: translateY(10px); } 
      to { opacity: 1; transform: translateY(0); } 
    }
    .animate-fade-in { 
      animation: fadeIn 0.4s ease-out forwards; 
    }
    
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    
    .btn-primary { 
      display: inline-flex; 
      align-items: center; 
      justify-content: center; 
      padding: 0.65rem 1.5rem; 
      background-color: #1e3a8a; 
      color: white; 
      font-weight: 700; 
      font-size: 0.875rem; 
      border-radius: 0.5rem; 
      transition: all 0.2s; 
      box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); 
      cursor: pointer; 
    }
    
    .btn-primary:hover:not(:disabled) { 
      background-color: #172554; 
      transform: translateY(-1px); 
    }
    
    .btn-primary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* --- Styles from Index.html --- */
    @keyframes shimmer {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    .accordion-content {
      transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out, margin 0.3s ease-in-out;
      max-height: 0;
      opacity: 0;
      overflow: hidden;
    }
    .accordion-content.open {
      max-height: 2000px;
      opacity: 1;
      margin-top: 1rem;
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans overflow-hidden">
  
  <div id="root"></div>

  <!-- VARIABLES GLOBALES & CONTEXTE -->
  <script type="text/babel">
    window.ContentContext = React.createContext();
    window.JOB_CODES = [];
    window.BU_DATA = [];
  </script>

  <!-- COMPOSANTS REACT MODULAIRES INTÉGRÉS -->
  <script type="text/babel">
    const { useState, useEffect, useContext, useMemo, useRef } = React;

    // --- UTILS & SHARED COMPONENTS ---
    
    // Composant Texte classique
    function T({ id, multiline = false }) {
      const { content, setContent, isEditMode } = useContext(window.ContentContext);
      const text = content[id] !== undefined ? content[id] : `[${id}]`;
      const inputRef = useRef(null);
      
      if (!isEditMode) {
        return <span dangerouslySetInnerHTML={{__html: text.replace(/\n/g, '<br/>')}} />;
      }

      const insertHTML = (tagOpen, tagClose) => {
        const el = inputRef.current;
        if (!el) return;
        const start = el.selectionStart;
        const end = el.selectionEnd;
        const val = el.value;
        const selectedText = val.substring(start, end);
        const replacement = tagOpen + (selectedText || "Texte") + tagClose;
        const newVal = val.substring(0, start) + replacement + val.substring(end);
        
        setContent({...content, [id]: newVal});
        
        setTimeout(() => {
          el.focus();
          el.setSelectionRange(start + tagOpen.length, start + tagOpen.length + (selectedText || "Texte").length);
        }, 0);
      };
      
      return (
        <div className="w-full flex flex-col my-1 text-slate-800 font-sans">
          <div className="flex flex-wrap gap-1 bg-amber-100 p-1 border-x-2 border-t-2 border-amber-400 rounded-t-lg items-center text-[10px] sm:text-xs">
            <button type="button" onClick={() => insertHTML('<strong>', '</strong>')} className="px-1.5 py-0.5 bg-white hover:bg-amber-200 rounded font-bold border border-amber-300 shadow-sm" title="Gras">B</button>
            <button type="button" onClick={() => insertHTML('<em>', '</em>')} className="px-1.5 py-0.5 bg-white hover:bg-amber-200 rounded italic border border-amber-300 shadow-sm" title="Italique">I</button>
            <button type="button" onClick={() => insertHTML('<u>', '</u>')} className="px-1.5 py-0.5 bg-white hover:bg-amber-200 rounded underline border border-amber-300 shadow-sm" title="Sous-ligner">U</button>
            <span className="text-amber-300 mx-1">|</span>
            <button type="button" onClick={() => insertHTML('<span class="text-blue-600">', '</span>')} className="px-1.5 py-0.5 bg-blue-100 text-blue-600 font-bold hover:bg-blue-200 rounded border border-blue-300 shadow-sm" title="Bleu">Bleu</button>
            <button type="button" onClick={() => insertHTML('<span class="text-red-600">', '</span>')} className="px-1.5 py-0.5 bg-red-100 text-red-600 font-bold hover:bg-red-200 rounded border border-red-300 shadow-sm" title="Rouge">Rouge</button>
            <button type="button" onClick={() => insertHTML('<span class="text-emerald-600">', '</span>')} className="px-1.5 py-0.5 bg-emerald-100 text-emerald-600 font-bold hover:bg-emerald-200 rounded border border-emerald-300 shadow-sm" title="Vert">Vert</button>
            <span className="text-amber-300 mx-1">|</span>
            {multiline && (
              <>
                <button type="button" onClick={() => insertHTML('<ul class="list-disc pl-5 my-2"><li>', '</li><li>Élément 2</li></ul>')} className="px-1.5 py-0.5 bg-white hover:bg-amber-200 rounded border border-amber-300 shadow-sm flex items-center gap-1" title="Liste à puces">
                  <i className="fas fa-list-ul text-[9px]"></i> Liste
                </button>
                <button type="button" onClick={() => insertHTML('<li class="mt-1">', '</li>')} className="px-1.5 py-0.5 bg-white hover:bg-amber-200 rounded border border-amber-300 shadow-sm" title="Ajouter une puce">+ Puce</button>
                <span className="text-amber-300 mx-1">|</span>
              </>
            )}
            <button type="button" onClick={() => insertHTML('<div class="pl-4 border-l-2 border-slate-300 my-2">', '</div>')} className="px-1.5 py-0.5 bg-white hover:bg-amber-200 rounded border border-amber-300 shadow-sm flex items-center gap-1" title="Indentation">
              <i className="fas fa-indent text-[9px]"></i> Indenter
            </button>
          </div>

          {multiline ? (
            <textarea 
              ref={inputRef}
              className="w-full min-h-[100px] p-2 border-x-2 border-b-2 border-amber-400 bg-amber-50 text-slate-900 rounded-b-lg outline-none text-sm font-normal normal-case leading-relaxed shadow-inner focus:ring-2 ring-amber-200"
              value={text}
              onChange={(e) => setContent({...content, [id]: e.target.value})}
              onClick={(e) => e.stopPropagation()}
            />
          ) : (
            <input 
              ref={inputRef}
              type="text" 
              className="w-full p-1.5 border-x-2 border-b-2 border-amber-400 bg-amber-50 text-slate-900 rounded-b-lg outline-none text-sm font-normal normal-case shadow-inner focus:ring-2 ring-amber-200"
              value={text}
              onChange={(e) => setContent({...content, [id]: e.target.value})}
              onClick={(e) => e.stopPropagation()}
            />
          )}
        </div>
      );
    }

    // Composant Texte Optionnel Dynamique
    function OptionalT({ id }) {
      const { content, setContent, isEditMode } = useContext(window.ContentContext);
      const text = content[id] || '';

      if (!isEditMode && !text) return null;

      if (isEditMode && !text) {
        return (
          <div className="border-2 border-dashed border-amber-300 p-3 text-center text-amber-600 rounded-xl cursor-pointer hover:bg-amber-50 mt-4 mb-4 transition-colors text-sm"
               onClick={() => setContent({...content, [id]: 'Nouveau texte optionnel...'})}>
            <i className="fas fa-plus-circle mr-2"></i> Ajouter un bloc de texte supplémentaire ici
          </div>
        );
      }

      return (
          <div className={`relative group mt-4 mb-4 ${isEditMode ? 'bg-amber-50/50 p-4 rounded-xl border border-amber-200' : ''}`}>
            {isEditMode && <div className="absolute -top-2.5 -left-2 bg-amber-200 text-amber-800 text-[10px] font-bold px-2 py-0.5 rounded shadow-sm z-10 border border-amber-300">Optionnel</div>}
            
            <div className="text-sm text-slate-600 leading-relaxed">
              <T id={id} multiline={true} />
            </div>
            
            {isEditMode && (
               <button onClick={() => setContent({...content, [id]: ''})} title="Supprimer ce bloc" className="absolute -top-2.5 -right-2 text-red-500 hover:text-red-700 bg-white rounded-full w-6 h-6 flex items-center justify-center shadow-md border border-red-200 transition-opacity z-10">
                 <i className="fas fa-trash text-xs"></i>
               </button>
            )}
          </div>
      );
    }

    // Composant Accordéon (Pour Partie 5 et autres)
    function Accordion({ titleId, icon, children, defaultOpen = false }) {
      const [isOpen, setIsOpen] = useState(defaultOpen);
      
      return (
        <div className="border border-slate-200 rounded-xl bg-white overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <button 
            className="w-full flex items-center justify-between p-4 bg-slate-50 hover:bg-slate-100 transition-colors focus:outline-none"
            onClick={() => setIsOpen(!isOpen)}
          >
            <div className="flex items-center text-slate-800 font-bold text-lg">
              <i className={`fas ${icon} text-indigo-500 mr-3 w-6 text-center`}></i>
              <T id={titleId} />
            </div>
            <i className={`fas fa-chevron-down text-slate-400 transition-transform duration-300 ${isOpen ? 'rotate-180' : ''}`}></i>
          </button>
          <div className={`accordion-content px-6 bg-white ${isOpen ? 'open pb-6' : ''}`}>
            {children}
          </div>
        </div>
      );
    }

    function NavItem({ icon, labelId, isActive, onClick, locked }) {
      return (
        <button 
          onClick={locked ? undefined : onClick}
          className={`w-full flex items-center px-6 py-3.5 text-xs font-bold transition-all relative
            ${isActive ? 'bg-[#132c4a] text-white border-l-4 border-blue-500 shadow-inner' : 'text-slate-300 hover:bg-[#132c4a]/50 hover:text-white border-l-4 border-transparent'}
            ${locked ? 'opacity-50 cursor-not-allowed' : ''}`}
        >
          <i className={`fas ${icon} w-6 text-center mr-3 text-sm ${isActive ? 'text-blue-400' : 'text-slate-500 group-hover:text-slate-300'}`}></i>
          <span className="flex-1 text-left whitespace-normal leading-tight"><T id={labelId} /></span>
          {locked ? <i className="fas fa-lock text-[10px] text-slate-500 ml-2"></i> : isActive && <i className="fas fa-chevron-right text-[10px] text-blue-500 opacity-50 ml-2"></i>}
        </button>
      );
    }

    // ==========================================
    // PARTIE 1 : CYCLE S&OP
    // ==========================================
    function Part1_CycleSOP({ onNext }) {
      const { gainXp, isDevMode, completedTasks } = useContext(window.ContentContext) || {};
      const isPart1Done = !!completedTasks['puzzle_p1'];

      const correctPuzzle = [
        { id: 4, textId: "p1_step4", order: 4, resp: 'mgr', inst: 'proj' },
        { id: 1, textId: "p1_step1", order: 1, resp: 'sop_mgr', inst: 'none' },
        { id: 5, textId: "p1_step5", order: 5, resp: 'copil', inst: 'rituel_sop' },
        { id: 2, textId: "p1_step2", order: 2, resp: 'pm', inst: 'avant_demande' },
        { id: 3, textId: "p1_step3", order: 3, resp: 'mgr', inst: 'none' }
      ];

      const [puzzleItems, setPuzzleItems] = useState([
        { id: 4, textId: "p1_step4", order: null, resp: '', inst: '' },
        { id: 1, textId: "p1_step1", order: null, resp: '', inst: '' },
        { id: 5, textId: "p1_step5", order: null, resp: '', inst: '' },
        { id: 2, textId: "p1_step2", order: null, resp: '', inst: '' },
        { id: 3, textId: "p1_step3", order: null, resp: '', inst: '' }
      ]);
      const [currentOrder, setCurrentOrder] = useState(1);
      const [isSuccess, setIsSuccess] = useState(false);
      const [showError, setShowError] = useState(false);

      useEffect(() => { window.scrollTo({ top: 0, behavior: 'smooth' }); }, []);

      useEffect(() => {
        if (completedTasks && completedTasks['puzzle_p1']) {
           setPuzzleItems(correctPuzzle);
           setIsSuccess(true);
           setShowError(false);
        } else if (isDevMode) {
           setPuzzleItems(correctPuzzle);
           setCurrentOrder(6);
           setIsSuccess(false);
           setShowError(false);
        } else {
           setPuzzleItems([
             { id: 4, textId: "p1_step4", order: null, resp: '', inst: '' },
             { id: 1, textId: "p1_step1", order: null, resp: '', inst: '' },
             { id: 5, textId: "p1_step5", order: null, resp: '', inst: '' },
             { id: 2, textId: "p1_step2", order: null, resp: '', inst: '' },
             { id: 3, textId: "p1_step3", order: null, resp: '', inst: '' }
           ]);
           setCurrentOrder(1);
           setIsSuccess(false);
           setShowError(false);
        }
      }, [completedTasks, isDevMode]);

      const handleOrderClick = (item) => {
        if (item.order !== null) {
          const newItems = puzzleItems.map(p => ({ ...p, order: null }));
          setPuzzleItems(newItems);
          setCurrentOrder(1);
          setShowError(false);
        } else {
          const newItems = puzzleItems.map(p => p.id === item.id ? { ...p, order: currentOrder } : p);
          setPuzzleItems(newItems);
          setCurrentOrder(currentOrder + 1);
          setShowError(false);
        }
      };

      const checkPuzzle = () => {
        const allFilled = puzzleItems.every(p => p.order !== null && p.resp !== '' && p.inst !== '');
        if (!allFilled) {
          setShowError("Veuillez remplir toutes les informations (Ordre, Responsable, Instance).");
          return;
        }

        const isOrderCorrect = puzzleItems.every(p => p.order === p.id);
        const isRespCorrect = puzzleItems.every(p => {
          if (p.id === 1) return p.resp === 'sop_mgr';
          if (p.id === 2) return p.resp === 'pm';     
          if (p.id === 3) return p.resp === 'mgr';    
          if (p.id === 4) return p.resp === 'mgr';    
          if (p.id === 5) return p.resp === 'copil';  
          return false;
        });

        const isInstCorrect = puzzleItems.every(p => {
          if (p.id === 1) return p.inst === 'none';         
          if (p.id === 2) return p.inst === 'avant_demande';
          if (p.id === 3) return p.inst === 'none';         
          if (p.id === 4) return p.inst === 'proj';         
          if (p.id === 5) return p.inst === 'rituel_sop';   
          return false;
        });

        if (isOrderCorrect && isRespCorrect && isInstCorrect) {
          setIsSuccess(true);
          setShowError(false);
          if (gainXp) gainXp('puzzle_p1'); 
        } else {
          setIsSuccess(false);
          setShowError("Il y a des erreurs dans l'ordre chronologique, les responsables ou les instances. Vérifiez vos choix !");
        }
      };

      return (
        <div className="space-y-8 animate-fade-in pb-10 flex flex-col min-h-[calc(100vh-100px)]">

          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <h2 className="text-2xl font-bold text-slate-800 mb-2 flex items-center">
              <i className="fas fa-sync-alt text-blue-600 mr-3"></i> <T id="p1_title" />
            </h2>
            <p className="text-slate-600"><T id="p1_desc" multiline={true} /></p>
            <OptionalT id="p1_opt_intro" />
          </div>

          <div className="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 relative overflow-hidden">
            <div className="absolute top-0 left-0 w-1.5 h-full bg-indigo-500"></div>
            <h3 className="font-bold text-slate-800 border-b border-slate-100 pb-3 mb-6 text-xl flex items-center pl-2">
              <i className="fas fa-balance-scale text-indigo-600 mr-3"></i> <T id="p1_s5_main_title" />
            </h3>
            <div className="pl-2">
              <p className="text-slate-700 mb-6 font-medium text-[15px] leading-relaxed"><T id="p1_s5_intro" multiline={true} /></p>
              <div className="relative w-full aspect-video rounded-xl overflow-hidden border border-slate-200 shadow-md bg-slate-100 flex items-center justify-center">
                <iframe 
                  src="https://docs.google.com/presentation/d/11OS-TNCQXm-rayUJDfuBODY3gjuCRuUQdYOFdfftVGo/embed?start=false&loop=false&delayms=3000&slide=id.g3e377d0dfa4_0_1805" 
                  frameBorder="0" 
                  width="100%" 
                  height="100%" 
                  allowFullScreen={true}
                  className="absolute top-0 left-0 w-full h-full">
                </iframe>
              </div>
            </div>
          </div>

          <div className="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 relative overflow-hidden">
            <div className="absolute top-0 left-0 w-1.5 h-full bg-blue-500"></div>
            <h3 className="font-bold text-slate-800 border-b border-slate-100 pb-3 mb-6 text-xl flex items-center pl-2">
              <i className="fas fa-project-diagram text-blue-600 mr-3"></i> <T id="p1_s14_main_title" />
            </h3>
            <div className="pl-2">
              <p className="text-slate-700 mb-8 font-medium text-[15px] leading-relaxed bg-blue-50 p-4 rounded-xl border border-blue-100">
                <T id="p1_s14_intro" multiline={true} />
              </p>
              <div className="relative border-l-2 border-slate-200 ml-4 space-y-8 pb-4 mt-8">
                <div className="relative pl-8">
                  <div className="absolute -left-[17px] top-0 w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center border-4 border-white shadow-sm"><i className="fas fa-database text-xs"></i></div>
                  <h4 className="font-bold text-slate-800 mb-2"><T id="p1_s14_collecte_title" /></h4>
                  <p className="text-sm text-slate-600 leading-relaxed"><T id="p1_s14_collecte_desc" multiline={true} /></p>
                </div>
                <div className="relative pl-8">
                  <div className="absolute -left-[17px] top-0 w-8 h-8 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center border-4 border-white shadow-sm"><i className="fas fa-chart-pie text-xs"></i></div>
                  <h4 className="font-bold text-slate-800 mb-2"><T id="p1_s14_demande_title" /></h4>
                  <p className="text-sm text-slate-600 leading-relaxed"><T id="p1_s14_demande_desc" multiline={true} /></p>
                </div>
                <div className="relative pl-8">
                  <div className="absolute -left-[17px] top-0 w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center border-4 border-white shadow-sm"><i className="fas fa-users text-xs"></i></div>
                  <h4 className="font-bold text-slate-800 mb-2"><T id="p1_s14_capa_title" /></h4>
                  <p className="text-sm text-slate-600 leading-relaxed"><T id="p1_s14_capa_desc" multiline={true} /></p>
                </div>
                <div className="relative pl-8">
                  <div className="absolute -left-[17px] top-0 w-8 h-8 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center border-4 border-white shadow-sm"><i className="fas fa-handshake text-xs"></i></div>
                  <h4 className="font-bold text-slate-800 mb-2"><T id="p1_s14_rituel_title" /></h4>
                  <p className="text-sm text-slate-600 leading-relaxed"><T id="p1_s14_rituel_desc" multiline={true} /></p>
                </div>
                <div className="relative pl-8">
                  <div className="absolute -left-[17px] top-0 w-8 h-8 bg-slate-200 text-slate-600 rounded-full flex items-center justify-center border-4 border-white shadow-sm"><i className="fas fa-file-invoice-dollar text-xs"></i></div>
                  <h4 className="font-bold text-slate-800 mb-2"><T id="p1_s14_finance_title" /></h4>
                  <p className="text-sm text-slate-600 leading-relaxed"><T id="p1_s14_finance_desc" multiline={true} /></p>
                </div>
              </div>
            </div>
          </div>

          <div className="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 relative">
            <h3 className="font-bold text-slate-800 border-b border-slate-100 pb-3 mb-6 text-xl flex items-center">
              <i className="fas fa-mouse-pointer text-blue-500 mr-3"></i> <T id="p1_game_title" />
            </h3>
            <div className="max-w-5xl mx-auto">
              <p className="text-sm text-slate-500 mb-6 uppercase tracking-wide font-semibold text-center">
                Reconstituez les 5 étapes de la procédure S&OP, et attribuez-y le Responsable et l'Instance correspondante.
              </p>
              <div className="space-y-4">
                {puzzleItems.map(item => (
                  <div key={item.id} className={`w-full flex flex-col xl:flex-row items-center p-4 rounded-xl border transition-all duration-200 gap-4 ${item.order !== null ? 'bg-blue-50/50 border-blue-200 shadow-inner' : 'bg-white border-slate-200 hover:border-blue-400 shadow-sm'}`}>
                    <div className="flex-1 flex items-center w-full">
                      <button onClick={() => handleOrderClick(item)} className={`w-10 h-10 flex items-center justify-center rounded-full text-sm font-bold mr-4 shrink-0 transition-colors shadow-sm ${item.order !== null ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-400 hover:bg-slate-200 hover:text-slate-600'}`}>
                        {item.order !== null ? item.order : '?'}
                      </button>
                      <span className="text-left font-medium text-slate-700 leading-relaxed text-sm"><T id={item.textId} multiline={true} /></span>
                    </div>
                    <div className="flex flex-col sm:flex-row gap-3 w-full xl:w-auto shrink-0 border-t xl:border-t-0 xl:border-l border-slate-200 pt-3 xl:pt-0 xl:pl-4">
                      <div className="flex flex-col">
                        <span className="text-[9px] uppercase font-bold text-slate-400 mb-1 ml-1">Responsable principal</span>
                        <select value={item.resp} onChange={(e) => { setPuzzleItems(puzzleItems.map(p => p.id === item.id ? { ...p, resp: e.target.value } : p)); setShowError(false); }} className="p-2 border border-slate-300 rounded-lg text-xs outline-none focus:border-blue-500 bg-white shadow-sm w-full sm:w-48">
                          <option value="">-- Choisir --</option>
                          <option value="sop_mgr">S&OP Manager</option>
                          <option value="pm">Responsable Prop. / PM</option>
                          <option value="mgr">Manager</option>
                          <option value="copil">Copil BU</option>
                        </select>
                      </div>
                      <div className="flex flex-col">
                        <span className="text-[9px] uppercase font-bold text-slate-400 mb-1 ml-1">Instance / Réunion</span>
                        <select value={item.inst} onChange={(e) => { setPuzzleItems(puzzleItems.map(p => p.id === item.id ? { ...p, inst: e.target.value } : p)); setShowError(false); }} className="p-2 border border-slate-300 rounded-lg text-xs outline-none focus:border-blue-500 bg-white shadow-sm w-full sm:w-48">
                          <option value="">-- Choisir --</option>

    function App() {
      const [currentPage, setCurrentPage] = useState('home');
      const [userSession, setUserSession] = useState(null); 
      const [content, setContent] = useState({});
      const [completedTasks, setCompletedTasks] = useState({});
      const [isLoading, setIsLoading] = useState(true);
      const [isRefreshing, setIsRefreshing] = useState(false);
      const [isEditMode, setIsEditMode] = useState(false);
      const [isDevMode, setIsDevMode] = useState(false);
      const [isSaving, setIsSaving] = useState(false);
      
      const [isHelpOpen, setIsHelpOpen] = useState(false);

      const xpMap = {
        nav_part1: 100, nav_part2: 100, nav_part3: 100, nav_part4: 100, nav_part5: 100,
        puzzle_p1: 50, ex_p2_ref: 50, ex_p2_algo: 50, matrix_p3: 50, assign_p5: 50,
        feedback: 50
      };
      const maxXP = 1260; 
      
      const xp = useMemo(() => {
        let total = 0;
        Object.keys(completedTasks).forEach(k => {
          if (xpMap[k]) total += xpMap[k];
          else if (k.startsWith('diag3_') || k.startsWith('diag4_') || k.startsWith('diag5_')) total += 20;
        });
        return Math.min(maxXP, total);
      }, [completedTasks]);

      const loadData = (isManualRefresh = false) => {
        if (isManualRefresh) setIsRefreshing(true);
        
        if (typeof google !== 'undefined' && google.script) {
          let dataLoaded = false;
          let codesLoaded = false;
          let buLoaded = false;

          const checkDone = () => {
            if (dataLoaded && codesLoaded && buLoaded) {
              setIsLoading(false);
              if (isManualRefresh) setIsRefreshing(false);
            }
          };

          google.script.run
            .withFailureHandler(err => { console.error("getContent error", err); dataLoaded = true; checkDone(); })
            .withSuccessHandler(data => { setContent(data || {}); window.reactContentContext = data || {}; dataLoaded = true; checkDone(); })
            .getContent();

          google.script.run
            .withFailureHandler(err => { console.error("getJobCodes error", err); codesLoaded = true; checkDone(); })
            .withSuccessHandler(codes => { window.JOB_CODES = codes || []; codesLoaded = true; checkDone(); })
            .getJobCodes();

          if (google.script.run.getBUData) {
            google.script.run
              .withFailureHandler(err => { 
                console.warn("getBUData manquant dans Code.gs."); 
                buLoaded = true; checkDone(); 
              })
              .withSuccessHandler(buData => { window.BU_DATA = buData || []; buLoaded = true; checkDone(); })
              .getBUData();
          } else {
            console.warn("getBUData manquant dans Code.gs."); 
            buLoaded = true; checkDone(); 
          }
        } else {
           // Fallback loading for non-Apps Script environment
           setTimeout(() => {
             setContent({
                'app_title': 'OPTIMA S&OP',
                'app_subtitle': 'Parcours Manager',
                'nav_home': 'Accueil & Guide',
                'nav_training_plan': 'Plan de Formation',
                'nav_p1': 'P1: Le Cycle S&OP',
                'nav_p2': 'P2: La Capacité',
                'nav_p3': 'P3: Gestion de Ressource',
                'nav_p4': 'P4: Gestion Avancée',
                'nav_p5': 'P5: Affectation de Charge',
                'home_title': 'Formation OPTIMA S&OP',
                'home_welcome': 'Bienvenue dans le nouveau parcours de formation pour les Managers. Ce programme a été segmenté en 5 parties pour couvrir l\'intégralité de vos responsabilités dans OPTIMA.',
                'home_email_title': 'Identification requise',
                'home_email_desc': 'Entrez votre email pour commencer et suivre votre progression. Si vous vous êtes déjà connecté, votre avancement sera restauré.',
                'home_prog_title': 'Programme',
                'home_prog_desc': 'Découvrez les étapes du programme de formation.\n- Le Cycle S&OP\n- La Capacité\n- Gestion des ressources\n- Avancé\n- Affectation',
                'home_obj_title': 'Objectifs',
                'home_obj_desc': 'Apprenez à gérer les ressources de votre périmètre et maîtriser les flux d\'affectation S&OP.',
                'home_agenda_title': 'Agenda',
                'home_agenda_desc': '5 modules de 10 à 15 minutes chacun, interactifs et gamifiés.',
                'home_howto_title': 'Comment jouer',
                'home_howto_desc': 'Suivez les instructions à l\'écran, interagissez avec les schémas et regardez les vidéos explicatives.'
             });
             setIsLoading(false);
             if (isManualRefresh) setIsRefreshing(false);
           }, 1000);
        }
      };

      useEffect(() => {
        loadData(false);
      }, []);

      const handleSave = () => {
        setIsSaving(true);
        if (typeof google !== 'undefined' && google.script) {
            google.script.run
              .withFailureHandler(err => { console.error("saveContent error", err); setIsSaving(false); setIsEditMode(false); })
              .withSuccessHandler(() => {
                setIsSaving(false);
                setIsEditMode(false);
                window.reactContentContext = content;
              }).saveContent(content);
        } else {
            setIsSaving(false);
            setIsEditMode(false);
        }
      };

      const gainXp = (key) => {
        if (key && !completedTasks[key]) {
           const now = new Date();
           const formattedDate = now.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });
           setCompletedTasks(prev => ({...prev, [key]: formattedDate}));
           
           if (typeof google !== 'undefined' && google.script && userSession && google.script.run.logUserProgress) {
              google.script.run
                .withFailureHandler(err => console.error("logUserProgress error", err))
                .logUserProgress(userSession.email, key, formattedDate);
           }
        }
      };

      const handleNavClick = (pageName) => {
        if (pageName !== currentPage) {
             setCurrentPage(pageName);
             gainXp('nav_' + pageName); 
        }
      };

      const handleResetProgress = () => {
        if (!userSession) return;
        if (window.confirm("Êtes-vous sûr de vouloir réinitialiser toute votre progression ? Vous retomberez à 0 XP.")) {
          if (typeof google !== 'undefined' && google.script && google.script.run.resetUserProgress) {
             google.script.run
               .withFailureHandler(err => {
                 console.warn("resetUserProgress manquant. Reset local uniquement.");
                 setCompletedTasks({});
                 setCurrentPage('home');
               })
               .withSuccessHandler(() => {
                 setCompletedTasks({});
                 setCurrentPage('home');
               }).resetUserProgress(userSession.email);
          } else {
             setCompletedTasks({});
             setCurrentPage('home');
          }
        }
      };

      const getHelpText = () => {
        if (!userSession) return "Saisissez votre e-mail pour débloquer la formation et passez à la Partie 1.";
        if (currentPage === 'home') return "Démarrez la Partie 1 en cliquant sur le bouton en bas de la page.";
        if (currentPage === 'part1') return !completedTasks['puzzle_p1'] ? "Reconstituez l'ordre chronologique du cycle S&OP (Jeu en bas de page) pour débloquer la suite." : "Section validée ! Vous pouvez passer à la Partie 2.";
        if (currentPage === 'part2') {
          const isRefDone = !!completedTasks['ex_p2_ref'];
          const isAlgoDone = !!completedTasks['ex_p2_algo'];
          if (!isRefDone && !isAlgoDone) return "Pour débloquer la suite, vous devez valider : L'exercice de recherche (Onglet A) et L'exercice de calcul (Onglet B).";
          if (!isRefDone) return "Pour débloquer la suite, vous devez valider : L'exercice de recherche (Onglet A).";
          if (!isAlgoDone) return "Pour débloquer la suite, vous devez valider : L'exercice de calcul (Onglet B).";
          return "Tous les exercices sont validés ! Vous pouvez passer à la Partie 3.";
        }
        if (currentPage === 'part3') {
          const activeStepsIds = ['1', '2', '3', '3b', '4', 'ongoing', '5', '7', '8'];
          const clickedStepsCount = activeStepsIds.filter(id => completedTasks[`diag3_${id}`]).length;
          if (clickedStepsCount < 9) return `Cliquez sur toutes les étapes du diagramme (${clickedStepsCount}/9) pour débloquer le test final.`;
          if (!completedTasks['matrix_p3']) return "Diagramme consulté. Validez le test (Onglet 2) pour continuer !";
          return "Diagramme et test validés ! Vous pouvez passer à la Partie 4.";
        }
        if (currentPage === 'part4') {
          const activeStepsIdsP4 = ['indispo', 'complex_mod', 'pret_req', 'pret_acc', 'pret_end', 'trans_req', 'trans_acc', 'trans_eff'];
          const clickedStepsCount = activeStepsIdsP4.filter(id => completedTasks[`diag4_${id}`]).length;
          if (clickedStepsCount < 8) return `Cliquez sur toutes les actions spécifiques, de prêt ou de transfert (${clickedStepsCount}/8) pour terminer.`;
          return "Diagramme consulté ! Vous pouvez passer à la Partie 5.";
        }
        if (currentPage === 'part5') {
          const clickedStepsCountP5 = ['L1','L2','L3','L4','L5','val'].filter(id => completedTasks[`diag5_${id}`]).length;
          if (clickedStepsCountP5 < 6) return `Cliquez sur chaque étape du diagramme interactif (Onglet Pratique) pour découvrir la procédure et débloquer le simulateur final (${clickedStepsCountP5}/6).`;
          return !completedTasks['assign_p5'] ? "Sauvegardez l'équipe ('Save the team') dans le simulateur en respectant exactement toutes les règles pour terminer." : "Formation terminée ! Laissez-nous votre avis dans l'onglet Conclusion.";
        }
        return "";
      };

      if (isLoading) {
        return (
          <div className="flex h-screen items-center justify-center bg-slate-50 flex-col">
            <i className="fas fa-circle-notch fa-spin text-4xl text-blue-600 mb-4"></i>
            <p className="text-slate-500 font-medium">Chargement du contenu et des référentiels...</p>
          </div>
        );
      }

      // Verrouillage du Menu Latéral (Strict)
      const isLocked = !userSession;
      const isPart1Done = !!completedTasks['puzzle_p1'];
      const isPart2Done = !!completedTasks['ex_p2_ref'] && !!completedTasks['ex_p2_algo'];
      const isPart3Done = !!completedTasks['matrix_p3'] && (new Set(Object.keys(completedTasks).filter(k => k.startsWith('diag3_'))).size === 9);
      
      const activeStepsIdsP4 = ['indispo', 'complex_mod', 'pret_req', 'pret_acc', 'pret_end', 'trans_req', 'trans_acc', 'trans_eff'];
      const isPart4Done = activeStepsIdsP4.every(id => completedTasks[`diag4_${id}`]);

      return (
        <window.ContentContext.Provider value={{ content, setContent, isEditMode, isDevMode, gainXp, completedTasks, setCompletedTasks }}>
          <div className="flex h-screen bg-slate-50 overflow-hidden relative">

            {/* Fenêtre Modale d'Aide (Popup) */}
            {isHelpOpen && (
              <div className="fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/50 backdrop-blur-sm p-4 animate-fade-in" onClick={() => setIsHelpOpen(false)}>
                <div className="bg-white rounded-2xl shadow-2xl max-w-md w-full overflow-hidden border border-slate-200 flex flex-col" onClick={e => e.stopPropagation()}>
                  <div className="bg-amber-400 p-4 flex items-center justify-between">
                    <h3 className="font-bold text-amber-950 flex items-center text-lg"><i className="fas fa-life-ring mr-2"></i> Objectif en cours</h3>
                    <button onClick={() => setIsHelpOpen(false)} className="text-amber-900 hover:bg-amber-500 w-8 h-8 rounded-full flex items-center justify-center transition-colors"><i className="fas fa-times"></i></button>
                  </div>
                  <div className="p-8 text-slate-700 font-medium text-center leading-relaxed">
                    {getHelpText()}
                  </div>
                  <div className="bg-slate-50 p-4 border-t border-slate-100 flex justify-center">
                    <button onClick={() => setIsHelpOpen(false)} className="bg-slate-800 hover:bg-slate-700 text-white px-8 py-2.5 rounded-xl font-bold transition-all shadow-sm">J'ai compris</button>
                  </div>
                </div>
              </div>
            )}

            {/* Barre de boutons haut-droite */}
            <div className="absolute top-4 right-4 z-50 flex items-center space-x-3 bg-white p-2 rounded-lg shadow-lg border border-slate-200">
              <button onClick={() => loadData(true)} disabled={isRefreshing} className="bg-slate-100 hover:bg-slate-200 text-slate-700 px-3 py-1.5 rounded-md text-xs font-bold shadow-sm flex items-center transition-colors border border-slate-300 disabled:opacity-50" title="Recharger les données">
                <i className={`fas fa-sync-alt mr-2 ${isRefreshing ? 'fa-spin text-blue-500' : ''}`}></i> {isRefreshing ? 'Mise à jour...' : 'Mettre à jour'}
              </button>
              
              <button onClick={handleResetProgress} disabled={!userSession} className={`px-3 py-1.5 rounded-md text-xs font-bold shadow-sm flex items-center transition-colors border ${userSession ? 'bg-red-50 hover:bg-red-100 text-red-600 border-red-200' : 'bg-slate-50 text-slate-300 border-slate-200 cursor-not-allowed'}`} title="Réinitialiser toute la progression (0 XP)">
                <i className="fas fa-trash-restore mr-2"></i> Réinitialiser
              </button>

              <div className="w-px h-6 bg-slate-200 mx-1"></div>

              <label className="flex items-center cursor-pointer text-sm font-bold text-slate-700">
                <div className="relative">
                  <input type="checkbox" className="sr-only" checked={isEditMode} onChange={() => setIsEditMode(!isEditMode)} />
                  <div className={`block w-10 h-6 rounded-full transition-colors ${isEditMode ? 'bg-amber-500' : 'bg-slate-300'}`}></div>
                  <div className={`dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform ${isEditMode ? 'transform translate-x-4' : ''}`}></div>
                </div>
                <span className="ml-3 mr-2"><i className="fas fa-pen text-amber-500 mr-1"></i> Mode Édition</span>
              </label>

              <label className="flex items-center cursor-pointer text-sm font-bold text-slate-700 border-l border-slate-200 pl-4 ml-2">
                <div className="relative">
                  <input type="checkbox" className="sr-only" checked={isDevMode} onChange={() => setIsDevMode(!isDevMode)} />
                  <div className={`block w-10 h-6 rounded-full transition-colors ${isDevMode ? 'bg-purple-500' : 'bg-slate-300'}`}></div>
                  <div className={`dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform ${isDevMode ? 'transform translate-x-4' : ''}`}></div>
                </div>
                <span className="ml-3 mr-2"><i className="fas fa-magic text-purple-500 mr-1"></i> Mode Dév</span>
              </label>

              {isEditMode && (
                <button onClick={handleSave} disabled={isSaving} className="bg-green-600 hover:bg-green-700 text-white px-4 py-1.5 rounded-md text-sm font-bold shadow-sm flex items-center transition-colors">
                  {isSaving ? <i className="fas fa-spinner fa-spin"></i> : <><i className="fas fa-save mr-2"></i> Sauvegarder</>}
                </button>
              )}
            </div>

            <nav className="w-80 bg-[#0c1e36] text-white flex flex-col shadow-2xl z-20 shrink-0">
              <div className="p-6 bg-[#081524] flex flex-col items-center border-b border-[#132c4a]">
                <div className="w-14 h-14 bg-white rounded-xl flex items-center justify-center mb-3 shadow-inner"><i className="fas fa-wind text-blue-500 text-2xl"></i></div>
                <h1 className="text-lg font-extrabold tracking-wider text-blue-100"><T id="app_title" /></h1>
                <p className="text-[10px] text-slate-400 mt-1 uppercase font-semibold"><T id="app_subtitle" /></p>
              </div>
              <div className="flex-1 overflow-y-auto py-4">
                <NavItem icon="fa-home" labelId="nav_home" isActive={currentPage === 'home'} onClick={() => setCurrentPage('home')} locked={false} />
                <div className="px-6 py-2 mt-4 text-[10px] font-bold text-slate-400 uppercase tracking-wider border-t border-[#132c4a] pt-4"><T id="nav_training_plan" /></div>
                <NavItem icon="fa-sync-alt" labelId="nav_p1" isActive={currentPage === 'part1'} onClick={() => handleNavClick('part1')} locked={isLocked} />
                <NavItem icon="fa-database" labelId="nav_p2" isActive={currentPage === 'part2'} onClick={() => handleNavClick('part2')} locked={isLocked || !isPart1Done} />
                <NavItem icon="fa-user-cog" labelId="nav_p3" isActive={currentPage === 'part3'} onClick={() => handleNavClick('part3')} locked={isLocked || !isPart2Done} />
                <NavItem icon="fa-level-up-alt" labelId="nav_p4" isActive={currentPage === 'part4'} onClick={() => handleNavClick('part4')} locked={isLocked || !isPart3Done} />
                <NavItem icon="fa-tasks" labelId="nav_p5" isActive={currentPage === 'part5'} onClick={() => handleNavClick('part5')} locked={isLocked || !isPart4Done} />
              </div>

              <div className="p-5 bg-[#081524] border-t border-[#132c4a] flex flex-col gap-2 shrink-0 z-30 shadow-[0_-4px_10px_rgba(0,0,0,0.2)]">
                <div className="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 px-1">Aide & Outils</div>
                
                <button onClick={() => setIsHelpOpen(true)} className="w-full flex items-center px-4 py-3 text-xs font-bold text-amber-400 hover:bg-amber-400/10 hover:text-amber-300 rounded-xl transition-all border border-transparent hover:border-amber-400/30 text-left shadow-sm">
                  <i className="fas fa-life-ring w-6 text-center mr-3 text-lg"></i> 
                  <span className="flex-1 leading-tight">Je suis perdu<br/><span className="text-[9px] font-normal text-amber-400/70">Voir l'objectif actuel</span></span>
                </button>

                <a href="https://notebooklm.google.com/notebook/87cccdd9-5317-478e-bcd6-b85d53510cd2" target="_blank" rel="noopener noreferrer" className="w-full flex items-center px-4 py-3 text-xs font-bold text-blue-400 hover:bg-blue-400/10 hover:text-blue-300 rounded-xl transition-all border border-transparent hover:border-blue-400/30 text-left group shadow-sm">
                  <i className="fas fa-robot w-6 text-center mr-3 text-lg group-hover:animate-pulse"></i> 
                  <span className="flex-1 leading-tight">Assistant IA<br/><span className="text-[9px] font-normal text-blue-400/70">Poser une question au bot</span></span>
                </a>

                <a href="https://gmtstore-pprd.apps.airliquide.com/webapp/app0053345_sop//dashboard" target="_blank" rel="noopener noreferrer" title="C'est une copie de l'application, vous pouvez y faire ce que vous voulez, amusez-vous!" className="w-full flex items-center px-4 py-3 text-xs font-bold text-emerald-400 hover:bg-emerald-400/10 hover:text-emerald-300 rounded-xl transition-all border border-transparent hover:border-emerald-400/30 text-left group shadow-sm">
                  <i className="fas fa-flask w-6 text-center mr-3 text-lg"></i> 
                  <span className="flex-1 leading-tight">Préproduction<br/><span className="text-[9px] font-normal text-emerald-400/70">Environnement Bac à sable</span></span>
                </a>
              </div>
            </nav>

            <div className="flex flex-col flex-1 overflow-hidden relative">
              {userSession && (
                <header className="bg-white border-b border-slate-200 h-16 flex items-center justify-between px-8 shrink-0 z-10 animate-fade-in shadow-sm">
                   <div className="flex items-center gap-4 flex-1 max-w-xl">
                     <div className="flex items-center gap-2"><i className="fas fa-trophy text-amber-500"></i><span className="text-xs font-bold text-slate-600 uppercase tracking-wider">Progression</span></div>
                     <div className="flex-1 h-3.5 bg-slate-100 rounded-full overflow-hidden border border-slate-200 shadow-inner">
                        <div className="h-full bg-gradient-to-r from-blue-500 to-emerald-400 transition-all duration-700 ease-out relative" style={{ width: `${Math.min((xp / maxXP) * 100, 100)}%` }}>
                          <div className="absolute inset-0 bg-white/20 w-full h-full animate-[shimmer_2s_infinite]"></div>
                        </div>
                     </div>
                     <span className="text-xs font-bold text-blue-700 bg-blue-50 px-2 py-1 rounded-md border border-blue-100">{xp} XP</span>
                   </div>
                   <div className="flex items-center gap-3 ml-8 border-l border-slate-200 pl-8">
                     <div className="text-right hidden md:block">
                       <div className="text-sm font-bold text-slate-800">{userSession.email}</div>
                       <div className="text-[10px] text-slate-500 font-medium">Session Manager S&OP</div>
                     </div>
                     <div className="w-10 h-10 rounded-full bg-gradient-to-br from-blue-100 to-indigo-100 text-blue-700 flex items-center justify-center font-bold text-lg border-2 border-white shadow-md">
                       {userSession.email.charAt(0).toUpperCase()}
                     </div>
                   </div>
                </header>
              )}

              <main className={`flex-1 overflow-y-auto bg-slate-50 relative px-8 pb-8 transition-all ${isEditMode ? 'border-4 border-amber-300' : ''}`}>
                <div className="max-w-6xl mx-auto pt-8">
                  {currentPage === 'home' && <HomeModule onNext={() => handleNavClick('part1')} userSession={userSession} setUserSession={setUserSession} gainXp={gainXp} />}
                  {currentPage === 'part1' && <Part1_CycleSOP onNext={() => handleNavClick('part2')} />}
                  {currentPage === 'part2' && <Part2_Capacity onNext={() => handleNavClick('part3')} />}
                  {currentPage === 'part3' && <Part3_ResourceMgmt onNext={() => handleNavClick('part4')} />}
                  {currentPage === 'part4' && <Part4_Advanced onNext={() => handleNavClick('part5')} />}
                  {currentPage === 'part5' && <Part5_Workload onNext={() => {}} userSession={userSession} />}
                </div>
              </main>
            </div>
          </div>
        </window.ContentContext.Provider>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
